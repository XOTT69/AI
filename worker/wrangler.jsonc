{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai1",
  "main": "worker.js",
  "compatibility_date": "2026-05-17",

  // Якщо використовуєш workers.dev route:
  "workers_dev": true,

  // Простi env vars, не secrets
  "vars": {
    "WORKER_PUBLIC_URL": "https://ai1.ai-beta69690.workers.dev",
    "R2_PUBLIC_URL": ""
  },

  // D1 binding
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai1",
      "database_id": "ccead4a8-b66f-4c1b-bee9-3032f9fd3dfc"
    }
  ],

  // R2 binding
  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "files"
    }
  ],

  // Workers AI binding
  "ai": {
    "binding": "AI"
  }

  // Secrets додаються окремо командами:
  // wrangler secret put GEMINI_API_KEY
  // wrangler secret put GROQ_API_KEY
  // wrangler secret put OPENROUTER_API_KEY
  // wrangler secret put NVIDIA_API_KEY
  // wrangler secret put MISTRAL_API_KEY
  // wrangler secret put CEREBRAS_API_KEY
  // wrangler secret put GITHUB_MODELS_TOKEN
}
